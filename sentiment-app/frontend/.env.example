# ── Frontend environment variables ───────────────────────────────────────────
# Copy this file to .env (for local dev) or .env.production (for prod builds).
# Vite only exposes variables prefixed with VITE_ to the browser bundle.

# URL of the backend API. No trailing slash.
# Dev default:        http://localhost:8000
# Docker Compose:     http://localhost:8000  (mapped via docker-compose ports)
# DO App Platform:    ${APP_URL}/api  (or the internal service URL)
VITE_API_URL=http://localhost:8000
